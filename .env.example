# ── SMTP Email Configuration ─────────────────────────────────
# Use your existing business email's SMTP settings.
# Ask your IT person or email provider for these values.
#
# Common providers:
#   Google Workspace:    SMTP_HOST=smtp.gmail.com          SMTP_PORT=587
#   Microsoft 365:       SMTP_HOST=smtp.office365.com      SMTP_PORT=587
#   cPanel / Hostinger:  SMTP_HOST=mail.yourdomain.com     SMTP_PORT=587
#   GoDaddy:             SMTP_HOST=smtpout.secureserver.net SMTP_PORT=465
#
# Note: Some providers require an "App Password" instead of
# your regular email password. Check your provider's docs.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
